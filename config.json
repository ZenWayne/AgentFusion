{
    "prompt_root": "config/prompt",
    "mcpServers": {
        "file_system": {
            "command": "npx",
            "args": [
                "@modelcontextprotocol/server-filesystem",
                "${cwd}"
            ],
            "env": {},
            "read_timeout_seconds": 30
        }
    },
    "agents": {
        "asci_human_proxy": {
            "name": "asci_human_proxy",
            "description": "ASCI系统的用户代理，接收用户研究课题并交付最终报告",
            "labels": ["ai_science", "human", "agent"],
            "type": "user_proxy_agent",
            "input_func": "input"
        },
        "asci_plan_reviewer": {
            "name": "asci_plan_reviewer",
            "description": "用户审批代理，负责审阅并批准Orchestrator制定的研究计划",
            "labels": ["ai_science", "human", "plan_review"],
            "type": "user_proxy_agent",
            "input_func": "input"
        },
        "asci_orchestrator": {
            "name": "asci_orchestrator",
            "description": "ASCI中央编排器，接收用户研究课题，制定研究计划，协调各子agent执行",
            "labels": ["ai_science", "orchestrator", "agent"],
            "type": "assistant_agent",
            "prompt_path": "agent/asci/orchestrator_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": [],
            "bash_enable": true,
            "graphrag_enable": true,
            "graphrag_embedding_model": "text-embedding-v4_DashScope",
            "graphrag_output_dir": "graphrag_output/asci_session"
        },
        "asci_explorer": {
            "name": "asci_explorer",
            "description": "文献发现Agent，搜索Google Scholar、阅读论文、构建GraphRAG知识图谱索引",
            "labels": ["ai_science", "explorer", "search", "agent"],
            "type": "assistant_agent",
            "prompt_path": "agent/asci/explorer_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": [],
            "bash_enable": true,
            "graphrag_enable": true,
            "graphrag_index_enable": true,
            "graphrag_model": "qwen3-max_DashScope",
            "graphrag_embedding_model": "text-embedding-v4_DashScope",
            "graphrag_output_dir": "graphrag_output/asci_session"
        },
        "asci_analyzer": {
            "name": "asci_analyzer",
            "description": "可行性分析Agent，利用GraphRAG知识图谱进行启发性分析，收敛为候选研究路线",
            "labels": ["ai_science", "analyzer", "agent"],
            "type": "assistant_agent",
            "prompt_path": "agent/asci/analyzer_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": [],
            "bash_enable": true,
            "graphrag_enable": true,
            "graphrag_embedding_model": "text-embedding-v4_DashScope",
            "graphrag_output_dir": "graphrag_output/asci_session"
        },
        "asci_critics": {
            "name": "asci_critics",
            "description": "质量门控验证Agent，利用GraphRAG溯源验证候选路线的引用准确性和逻辑一致性",
            "labels": ["ai_science", "critics", "validation", "agent"],
            "type": "assistant_agent",
            "prompt_path": "agent/asci/critics_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": [],
            "bash_enable": true,
            "graphrag_enable": true,
            "graphrag_embedding_model": "text-embedding-v4_DashScope",
            "graphrag_output_dir": "graphrag_output/asci_session"
        },
        "asci_executor": {
            "name": "asci_executor",
            "description": "PoC执行Agent，接收验证通过的方案，执行概念验证实验并收集结果",
            "labels": ["ai_science", "executor", "agent"],
            "type": "code_agent",
            "prompt_path": "agent/asci/executor_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": ["file_system"],
            "bash_enable": true,
            "handoff_tools": [
                {
                    "target": "asci_human_proxy",
                    "message": "Transfer to user for execution review"
                }
            ]
        },
        "asci_reporter": {
            "name": "asci_reporter",
            "description": "研究报告生成Agent，利用GraphRAG知识图谱综合分析和执行结果，生成带溯源引用的结构化研究报告",
            "labels": ["ai_science", "reporter", "agent"],
            "type": "assistant_agent",
            "prompt_path": "agent/asci/reporter_pt.md",
            "model_client": "deepseek-chat_DeepSeek",
            "mcp_tools": [],
            "bash_enable": true,
            "graphrag_enable": true,
            "graphrag_embedding_model": "text-embedding-v4_DashScope",
            "graphrag_output_dir": "graphrag_output/asci_session"
        }
    },
    "group_chats": {},
    "graph_flows": {
        "ai_science": {
            "name": "asci_research_flow",
            "description": "ASCI科研选题助手完整管线: Orchestrator → Explorer → Analyzer ↔ Critics → Executor → Reporter",
            "labels": ["ai_science", "graph_flow", "research"],
            "type": "graph_flow",
            "participants": [
                "asci_human_proxy",
                "asci_plan_reviewer",
                "asci_orchestrator",
                "asci_explorer",
                "asci_analyzer",
                "asci_critics",
                "asci_executor",
                "asci_reporter"
            ],
            "nodes": [
                ["asci_human_proxy", "asci_orchestrator"],
                ["asci_orchestrator", {
                    "<Explore>": "asci_explorer",
                    "<ReviewPlan>": "asci_plan_reviewer"
                }],
                ["asci_plan_reviewer", {
                    "": ["asci_orchestrator", "plan_review_loop"]
                }],
                ["asci_explorer", "asci_analyzer"],
                ["asci_analyzer", "asci_critics"],
                ["asci_critics", {
                    "<Approve>": "asci_executor",
                    "<Reject>": ["asci_analyzer", "critic_loop"]
                }],
                ["asci_executor", "asci_reporter"],
                ["asci_reporter", "asci_human_proxy"]
            ],
            "start_node": "asci_human_proxy"
        }
    }
}
